{
    "name": "@diia-inhouse/validators",
    "version": "1.28.17",
    "description": "Data validators package",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-validators",
    "author": "Diia",
    "license": "SEE LICENCE IN LICENCE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release -e @diia-inhouse/configs/dist/semantic-release/service-stage ",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular ./"
    },
    "dependencies": {
        "bson": "7.2.0",
        "fastest-validator": "1.19.1",
        "lodash.frompairs": "4.0.1",
        "luxon": "3.7.2"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=1.0.0",
        "@diia-inhouse/types": ">=2.5.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/errors": "1.18.11",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.12",
        "@diia-inhouse/types": "11.7.0",
        "@types/lodash.frompairs": "4.0.9",
        "@types/luxon": "3.7.1",
        "@types/node": "25.3.2",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.30.1",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.1",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
